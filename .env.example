# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=2434
JWT_SECRET=change-this-to-a-long-random-secret

# ── UPI Payment (REQUIRED) ────────────────────────────────────────────────────
# Your UPI ID — customers will pay to this
UPI_ID=yourname@upi
# Your name as it appears on UPI apps
MERCHANT_NAME=VOID Store

# ── Delivery Charges (₹) ─────────────────────────────────────────────────────
DELIVERY_CHARGE=99
FREE_DELIVERY_ABOVE=999

# ── Cloudinary (for worldwide image storage) ──────────────────────────────────
# Get free at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
